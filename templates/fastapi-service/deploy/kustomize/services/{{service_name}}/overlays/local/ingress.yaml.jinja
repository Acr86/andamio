apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: {{ service_name }}
spec:
  ingressClassName: traefik
  rules:
    - host: {{ service_name }}.127.0.0.1.nip.io
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: {{ service_name }}
                port:
                  name: http
