KUBE_PROMETHEUS_STACK_VERSION=77.0.1
LOKI_VERSION=6.41.1
PROMTAIL_VERSION=6.17.1

# Cluster identity
CLUSTER_NAME=andamio
INGRESS_HTTP_PORT=8080
